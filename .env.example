# Crowd Canvas — environment template.
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored — never commit real secrets.
#
# On the server `.env` lives at /opt/crowd-canvas/.env and is read by
# ecosystem.config.cjs when pm2 (re)starts the app.
# (PORT / HOST / UV_THREADPOOL_SIZE are set in ecosystem.config.cjs, not here.)

# Admin token — protects all admin endpoints and the admin WebSocket.
# Generate a strong one with:   openssl rand -hex 32
# Leave empty ONLY for local dev; an empty token means the admin API is OPEN.
ADMIN_TOKEN=
